# This is the SD card we are going to write to
# Don't run this script until you are sure this is
# the correct device for your system!!  Failure to 
# do so could result in your primary filesystem being
# wiped out!
SD=/dev/sdb

# Make sure we're running via sudo
if [ $(id -u) -ne 0 ]; then
    sudo $0 $1 $2 $3 $4 $5
    exit
fi


update_boot_partition()
{
    #
    # Mount the first paritition and copy the boot files
    #
    echo "Copying boot files to ${SD}1..."
    dst=/media/sd1
    mkdir -p     $dst
    mount ${SD}1 $dst
    cp $src/BOOT.BIN $dst
    cp $src/boot.scr $dst
    cp $src/image.ub $dst

    # We're done
    umount ${SD}1
}


# Check to see if the user only wants to update the boot partition
update_only=0;
if [ "$1" == "-update" ] || [ "$1" == "--update" ]; then
    shift
    update_only=1
fi

# Check for unrecognized command parameters
if [ ! -z $1 ]; then
    echo "Unrecognized parameters on command line" 1>&2
    exit 1
fi

#
#  Check to see if the SD card exists
#
if [ ! -b $SD ]; then
    echo $SD not found.  Halted.
    exit 1
fi


#
#  Figure out where the boot files are
#
if [ -f images/linux/BOOT.BIN ]; then 
    src=images/linux
elif [ -f linux/images/BOOT.BIN ]; then
    src=linux/images
else
    echo "BOOT.BIN not found!"
    exit 1
fi

#
# Ensure that there are no SD cards mounted
#
umount /dev/sd* 2>/dev/null


# If we're just updating the boot partition, make it so
if [ $update_only -eq 1 ]; then
    update_boot_partition
    echo "Boot partition updated"
    exit 0
fi

# Tell the user what we're up to
echo "Erasing $SD..."

# Ensure that there are no file-system signatures on the card
test -e ${SD}1 && wipefs --all ${SD}1 >/dev/null
test -e ${SD}2 && wipefs --all ${SD}2 >/dev/null
sleep 2

# Delete all partitions
fdisk $SD <<EOT >/dev/null 2>/dev/null
d

d

d

w
EOT



#
# Create the two partitions
#
echo "Creating partitions..."
fdisk $SD <<EOT >/dev/null 
n
p
1

+512M
n
p
2


w
EOT

#
# Create the FAT file-system for booting
#
echo "Creating FAT file-system..."
mkfs.fat ${SD}1 >/dev/null

#
# Create the EXT4 Linux filesystem
#
echo "Creating EXT4 file-system..."
mkfs.ext4 ${SD}2 >/dev/null 2>/dev/null

# Copy our files to the boot partition
update_boot_partition

